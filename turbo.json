{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "lib/**", "lib-esm/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!ARCHITECTURE.md",
        "!src/**/*.test.*",
        "!src/**/*.browser.test.*",
        "!src/**/__tests__/**",
        "!src/**/__snapshots__/**",
        "!config/vitest/**",
        "!vitest.config.*"
      ],
      "env": ["BABEL_MODULE", "NODE_ENV"]
    },
    "build:storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!ARCHITECTURE.md",
        "!src/**/*.test.*",
        "!src/**/*.browser.test.*",
        "!src/**/__tests__/**",
        "!src/**/__snapshots__/**",
        "!config/vitest/**",
        "!vitest.config.*"
      ],
      "env": ["DEPLOY_ENV", "VITE_*"]
    },
    "build:components.json:storybook": {
      "dependsOn": ["build:storybook"],
      "outputs": ["generated/components.json"]
    },
    "build:hooks.json": {
      "outputs": ["generated/hooks.json"]
    },
    "lint:npm": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "//#format:diff": {
      "outputs": []
    },
    "//#lint": {
      "outputs": []
    },
    "//#lint:css": {
      "outputs": []
    },
    "//#lint:md": {
      "outputs": []
    },
    "//#test:classname-coverage": {
      "outputs": []
    }
  },
  "futureFlags": {
    "affectedUsingTaskInputs": true,
    "filterUsingTasks": true
  },
  "globalDependencies": [".nvmrc", "tsconfig.base.json"]
}
