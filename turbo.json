{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "lib/**", "lib-esm/**", "generated/**"],
      "env": ["BABEL_MODULE", "NODE_ENV"]
    },
    "build:storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "env": ["DEPLOY_ENV", "VITE_*"]
    },
    "lint:npm": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  },
  "globalDependencies": [".nvmrc", "tsconfig.base.json"]
}
