{
  "name": "@primer/mcp",
  "description": "An MCP server that connects AI tools to the Primer Design System",
  "version": "0.4.0",
  "type": "module",
  "bin": {
    "mcp": "./bin/mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./transports/stdio": {
      "types": "./dist/transports/stdio.d.ts",
      "default": "./dist/stdio.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/primer/react.git"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rolldown -c",
    "test": "vitest --run",
    "type-check": "tsc --noEmit",
    "watch": "rolldown -c -w"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "@primer/octicons": "^19.15.5",
    "@primer/primitives": "10.x || 11.x",
    "@primer/react": "^38.30.0",
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.16.6",
    "@primer/vitest-config": "^0.0.0",
    "@types/turndown": "^5.0.5",
    "rimraf": "^6.0.1",
    "rolldown": "^1.1.4",
    "rolldown-plugin-dts": "^0.26.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
