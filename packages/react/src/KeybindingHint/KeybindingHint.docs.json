{
  "id": "keybinding-hint",
  "name": "KeybindingHint",
  "status": "alpha",
  "a11yReviewed": "2025-01-08",
  "stories": [
    {
      "id": "experimental-components-keybindinghint--default"
    },
    {
      "id": "experimental-components-keybindinghint-features--condensed"
    },
    {
      "id": "experimental-components-keybindinghint-features--full"
    },
    {
      "id": "experimental-components-keybindinghint-features--sequence-condensed"
    },
    {
      "id": "experimental-components-keybindinghint-features--sequence-full"
    },
    {
      "id": "experimental-components-keybindinghint-features--on-emphasis"
    },
    {
      "id": "experimental-components-keybindinghint-features--on-primary"
    },
    {
      "id": "experimental-components-keybindinghint-features--small"
    }
  ],
  "importPath": "@primer/react/experimental",
  "props": [
    {
      "name": "keys",
      "type": "string",
      "required": true,
      "description": "The keys involved in this keybinding."
    },
    {
      "name": "format",
      "type": "'condensed' | 'full'",
      "defaultValue": "'condensed'",
      "description": "Control the display format."
    },
    {
      "name": "variant",
      "type": "'normal' | 'onEmphasis' | 'onPrimary'",
      "defaultValue": "'normal'",
      "description": "Set to `onEmphasis` for display on emphasis colors, or `onPrimary` for display on primary buttons."
    },
    {
      "name": "size",
      "type": "'small' | 'normal'",
      "defaultValue": "'normal'",
      "description": "Control the size of the hint."
    }
  ],
  "subcomponents": []
}
