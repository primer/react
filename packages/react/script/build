#!/bin/bash

set -e

# Clean up
pnpm run clean

# Generate color schemes
pnpm run build:precompile-color-schemes

# Generate types for CSS Modules
pnpm run type-css-modules

# Bundle
pnpm exec rollup -c

# Type check
pnpm exec tsc --project tsconfig.build.json

# Build components.json file for documentation
pnpm run build:components.json

# Build hooks.json file for documentation
pnpm run build:hooks.json
