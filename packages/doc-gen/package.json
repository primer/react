{
  "name": "@primer/doc-gen",
  "private": true,
  "description": "A documentation generator for the Primer Design System",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "doc-gen": "./bin/doc-gen.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "rolldown -c",
    "type-check": "tsc --noEmit",
    "watch": "rolldown -c -w",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/signale": "^1.4.7",
    "@types/yargs": "^17.0.33",
    "prettier": "^3.4.2",
    "signale": "^1.4.0",
    "typescript": "^6.0.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "rolldown": "^1.1.2",
    "rolldown-plugin-dts": "^0.26.0",
    "typescript": "^6.0.3"
  }
}
